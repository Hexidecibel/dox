schema = 1

[defaults]
target_vault = "cush"
target_item = "doc-upload-site"
field_template = "{key}"

[secrets]
JWT_SECRET = { ref = "op://cush/doc-upload-site/jwt_secret", target_vault = "cush", target_item = "doc-upload-site" }
RESEND_API_KEY = { ref = "op://cush/doc-upload-site/resend_api_key", target_vault = "cush", target_item = "doc-upload-site" }
QWEN_URL = { ref = "op://cush/doc-upload-site/qwen_url", target_vault = "cush", target_item = "doc-upload-site" }
QWEN_SECRET = { ref = "op://cush/doc-upload-site/qwen_secret", target_vault = "cush", target_item = "doc-upload-site" }
CLOUDFLARE_API_TOKEN = { ref = "op://cush/doc-upload-site/cloudflare_api_token", target_vault = "cush", target_item = "doc-upload-site" }
CLOUDFLARE_ACCOUNT_ID = { ref = "op://cush/doc-upload-site/cloudflare_account_id", target_vault = "cush", target_item = "doc-upload-site" }
CLOUDFLARE_ZONE_ID_SUPDOX = { ref = "op://cush/doc-upload-site/cloudflare_zone_id_supdox", target_vault = "cush", target_item = "doc-upload-site" }
