# cush-tools — refresh .dev.vars from 1Password on cd
# Cloudflare Workers project: secrets live in .dev.vars (dev) and .dev.vars.staging
# Requires direnv — `direnv allow` in this dir to enable.
if command -v /home/hexi/local/src/cush-tools/bin/inject >/dev/null; then
  /home/hexi/local/src/cush-tools/bin/inject --no-prompt --out .dev.vars 2>/dev/null || true
  /home/hexi/local/src/cush-tools/bin/inject --no-prompt --manifest .cush-secrets.staging --out .dev.vars.staging 2>/dev/null || true
fi
[ -f .dev.vars ] && dotenv .dev.vars
