schema = 1

[defaults]
target_vault = "cush"
target_item = "doc-upload-site-prod"
field_template = "{key}"

[secrets]
TURNSTILE_SECRET = { ref = "op://cush/doc-upload-site-prod/turnstile_secret", target_vault = "cush", target_item = "doc-upload-site-prod" }
CONNECTOR_POLL_TOKEN = { ref = "op://cush/doc-upload-site-prod/connector_poll_token", target_vault = "cush", target_item = "doc-upload-site-prod" }
INTAKE_ENCRYPTION_KEY = { ref = "op://cush/doc-upload-site-prod/intake_encryption_key", target_vault = "cush", target_item = "doc-upload-site-prod" }
CLOUDFLARE_API_TOKEN = { ref = "op://cush/doc-upload-site/cloudflare_api_token", target_vault = "cush", target_item = "doc-upload-site" }
CLOUDFLARE_ACCOUNT_ID = { ref = "op://cush/doc-upload-site/cloudflare_account_id", target_vault = "cush", target_item = "doc-upload-site" }
