#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

if [ -z "${DOX_API_KEY:-}" ]; then
  echo "Error: DOX_API_KEY environment variable required"
  echo "Create an API key in dox admin, then: DOX_API_KEY=dox_sk_... bin/process-worker-start"
  exit 1
fi

export DOX_API_URL="${DOX_API_URL:-https://dox.cush.rocks}"
export QWEN_URL="${QWEN_URL:-https://qwen.cush.rocks}"
export QWEN_SECRET="${QWEN_SECRET:-f8d806a55d8e50230153dc68d7782a7747b28cc81bef9fc59d458ff46faf0840}"

mkdir -p logs

nohup node bin/process-worker > logs/process-worker.log 2>&1 &
echo "Process worker started (PID: $!)"
echo "Logs: logs/process-worker.log"
echo "Stop: kill $!"
