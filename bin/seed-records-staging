#!/usr/bin/env bash
# Seed realistic Records sample data into the staging D1
# (doc-upload-db-staging) for evaluating the Records list page and the
# upcoming Grid view against data that mirrors the partner's actual
# Smartsheet workflow.
#
# Idempotent: every INSERT keys on a stable id and uses
# ON CONFLICT(id) DO UPDATE SET ... so re-running converges. Safe to
# re-run after schema migrations or while iterating on copy.
#
# Scope: tenant_id='default' only. Never touches other tenants, never
# touches prod (uses --config=wrangler.staging.toml which targets
# doc-upload-db-staging).
#
# Tables touched:
#   suppliers, products, customers
#   records_sheets, records_columns, records_rows, records_row_refs,
#   records_views, records_activity
# Tables intentionally skipped (per spec):
#   records_row_attachments, records_comments, plus any
#   forms/workflows/automations tables which don't exist yet (Phase 2/3).
#
# Usage:
#   ./bin/seed-records-staging
set -euo pipefail
cd "$(dirname "$0")/.."

STAGING_DB="doc-upload-db-staging"
WRANGLER_CFG="wrangler.staging.toml"
TENANT_ID="default"

echo "==> Seeding Records sample data into ${STAGING_DB}"

# --- Pre-flight: confirm default tenant exists ---------------------
TENANT_CHECK=$(npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT COUNT(*) as n FROM tenants WHERE id='${TENANT_ID}';" 2>/dev/null \
  | grep -oE '"n": *[0-9]+' | grep -oE '[0-9]+' || echo "0")
if [ "${TENANT_CHECK}" = "0" ]; then
  echo "ERROR: tenant '${TENANT_ID}' missing in ${STAGING_DB}. Run bin/seed-staging first."
  exit 1
fi

TMPFILE=$(mktemp /tmp/seed-records-staging.XXXXXX.sql)
trap "rm -f $TMPFILE" EXIT

# ------------------------------------------------------------------
# Step 1: suppliers + products (idempotent via stable IDs)
# ------------------------------------------------------------------
cat > "$TMPFILE" <<'SQL'
-- =========================================================
-- SUPPLIERS (tenant=default)
-- =========================================================
INSERT INTO suppliers (id, tenant_id, name, slug, aliases, active)
VALUES
  ('sup-auburn',    'default', 'Auburn Dairy Products', 'auburn-dairy-products', NULL, 1),
  ('sup-pacific',   'default', 'Pacific Coast Foods',   'pacific-coast-foods',   NULL, 1),
  ('sup-northern',  'default', 'Northern Mills Co.',    'northern-mills-co',     NULL, 1),
  ('sup-riverside', 'default', 'Riverside Packaging',   'riverside-packaging',   NULL, 1)
ON CONFLICT(id) DO UPDATE SET
  name=excluded.name, slug=excluded.slug, active=1, updated_at=datetime('now');

-- =========================================================
-- PRODUCTS (tenant=default)
-- =========================================================
INSERT INTO products (id, tenant_id, name, slug, description, active)
VALUES
  ('prod-yogurt-32oz',  'default', 'Yogurt 32oz',     'yogurt-32oz',     'Plain whole-milk yogurt, 32oz cup', 1),
  ('prod-cheese-block', 'default', 'Cheese Block 5lb','cheese-block-5lb','Cheddar block, 5lb',                1),
  ('prod-milk-gallon',  'default', 'Milk Gallon',     'milk-gallon',     'Whole milk, 1gal jug',              1),
  ('prod-kraft-roll',   'default', 'Kraft Paper Roll','kraft-paper-roll','Brown kraft roll, 36in wide',       1)
ON CONFLICT(id) DO UPDATE SET
  name=excluded.name, slug=excluded.slug, description=excluded.description, active=1, updated_at=datetime('now');

-- =========================================================
-- CUSTOMERS (tenant=default)
-- The Quality Intake "customer" column is a customer_ref now, so the
-- values that used to live in records_rows.data as strings are seeded
-- here as real customer rows. customer_number is synthesized (CUST-####)
-- since these are dogfood retailers, not ERP-driven.
-- =========================================================
INSERT INTO customers (id, tenant_id, customer_number, name, email, coa_delivery_method, active)
VALUES
  ('cust-wf-bellevue',   'default', 'CUST-1001', 'Whole Foods Bellevue',       NULL, 'email', 1),
  ('cust-costco-kirk',   'default', 'CUST-1002', 'Costco Kirkland',            NULL, 'email', 1),
  ('cust-pcc-edmonds',   'default', 'CUST-1003', 'PCC Edmonds',                NULL, 'email', 1),
  ('cust-tc-millcreek',  'default', 'CUST-1004', 'Town & Country Mill Creek',  NULL, 'email', 1),
  ('cust-met-market',    'default', 'CUST-1005', 'Met Market',                 NULL, 'email', 1),
  ('cust-wf-roosevelt',  'default', 'CUST-1006', 'Whole Foods Roosevelt',      NULL, 'email', 1)
ON CONFLICT(id) DO UPDATE SET
  customer_number=excluded.customer_number, name=excluded.name, email=excluded.email,
  coa_delivery_method=excluded.coa_delivery_method, active=1, updated_at=datetime('now');

-- =========================================================
-- SHEETS
-- =========================================================
INSERT INTO records_sheets (id, tenant_id, name, slug, description, icon, color, template_key, archived)
VALUES
