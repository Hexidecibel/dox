# ------------------------------------------------------------------
# Apply the seed via wrangler (--remote = staging cloud DB)
# ------------------------------------------------------------------
echo "==> Applying seed SQL to ${STAGING_DB} (remote)..."
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" --file="$TMPFILE"

# ------------------------------------------------------------------
# Verification
# ------------------------------------------------------------------
echo ""
echo "==> Verification queries:"

echo "-- Sheets:"
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT id, name FROM records_sheets WHERE tenant_id='default' ORDER BY id;" 2>/dev/null \
  | grep -E '"id"|"name"' | head -10

echo "-- Columns per sheet:"
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT sheet_id, COUNT(*) as n FROM records_columns WHERE tenant_id='default' GROUP BY sheet_id ORDER BY sheet_id;" 2>/dev/null \
  | grep -E '"sheet_id"|"n"' | head -10

echo "-- Rows per sheet:"
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT sheet_id, COUNT(*) as n FROM records_rows WHERE tenant_id='default' GROUP BY sheet_id ORDER BY sheet_id;" 2>/dev/null \
  | grep -E '"sheet_id"|"n"' | head -10

echo "-- Row refs per sheet:"
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT sheet_id, COUNT(*) as n FROM records_row_refs WHERE tenant_id='default' GROUP BY sheet_id ORDER BY sheet_id;" 2>/dev/null \
  | grep -E '"sheet_id"|"n"' | head -10

echo "-- Activity total:"
npx wrangler d1 execute "$STAGING_DB" --remote --config="$WRANGLER_CFG" \
  --command="SELECT COUNT(*) as n FROM records_activity WHERE tenant_id='default';" 2>/dev/null \
  | grep -E '"n"' | head -2

echo ""
echo "==> Done."
