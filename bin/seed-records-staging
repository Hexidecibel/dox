-- =========================================================
-- DEFAULT GRID VIEWS (one per sheet, shared, default)
-- config: sort by display_order=1 column ascending, all columns visible
-- (visible_columns omitted = all visible per API convention).
-- =========================================================
INSERT INTO records_views (id, sheet_id, tenant_id, name, view_type, config, is_default, shared)
VALUES
  ('view-quality-grid', 'sheet-quality', 'default', 'Grid', 'grid',
   '{"filters":[],"sorts":[{"column_key":"date_reported","direction":"asc"}],"row_height":"medium"}', 1, 1),
  ('view-credits-grid', 'sheet-credits', 'default', 'Grid', 'grid',
   '{"filters":[],"sorts":[{"column_key":"request_date","direction":"asc"}],"row_height":"medium"}', 1, 1),
  ('view-audit-grid',   'sheet-audit',   'default', 'Grid', 'grid',
   '{"filters":[],"sorts":[{"column_key":"audit_date","direction":"asc"}],"row_height":"medium"}',   1, 1)
ON CONFLICT(id) DO UPDATE SET
  name=excluded.name, view_type=excluded.view_type, config=excluded.config,
  is_default=1, shared=1, updated_at=datetime('now');

-- =========================================================
-- ACTIVITY — one "created" entry per row + "updated" entries for rows
-- whose status moved (resolved / awaiting / investigating). Stable id
-- = "act-<row>-<kind>" so re-runs converge.
-- details JSON shape per kind:
--   created -> {} (or omitted)
--   updated -> {"column":"status","from":"...","to":"..."}
-- =========================================================
