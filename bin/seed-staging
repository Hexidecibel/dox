#!/usr/bin/env bash
# Seed the staging D1 with logins and a default tenant.
#
# Two accounts are seeded so A/B eval attribution separates the primary
# reviewer from their partner:
#   1. a@a.a / a  — super_admin (id='admin', tenant_id=NULL)
#   2. p@p.p / p  — user         (id='partner', tenant_id='default')
#
# Staging uses trivial credentials for fast manual login. The login
# endpoint does not enforce email/password validation — only
# register/create-user does — so we can bypass those rules by seeding
# directly into the DB. STAGING IS NOT EXPOSED WITH REAL DATA. Do not
# copy this pattern into bin/seed (prod).
set -euo pipefail
cd "$(dirname "$0")/.."

STAGING_DB="doc-upload-db-staging"

# --- Admin (super_admin, no tenant) ---
ADMIN_EMAIL="a@a.a"
ADMIN_PASSWORD="a"

# --- Partner (user role, default tenant — needed for eval attribution) ---
PARTNER_EMAIL="p@p.p"
PARTNER_PASSWORD="p"

if [ ! -f .dev.vars ]; then
  echo "ERROR: .dev.vars not found." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .dev.vars
set +a

# PBKDF2 hash (format: hex(salt):hex(derived)) — matches functions/lib/auth.ts.
# Each user gets an independent salt so hashes are not interchangeable.
hash_password() {
  PW="$1" node -e "
    const crypto = require('crypto');
    const salt = crypto.randomBytes(16);
    const derived = crypto.pbkdf2Sync(process.env.PW, salt, 100000, 32, 'sha256');
    console.log(salt.toString('hex') + ':' + derived.toString('hex'));
  "
}

ADMIN_PASSWORD_HASH=$(hash_password "$ADMIN_PASSWORD")
PARTNER_PASSWORD_HASH=$(hash_password "$PARTNER_PASSWORD")

TMPFILE=$(mktemp)
trap "rm -f $TMPFILE" EXIT

cat > "$TMPFILE" <<SQL
-- Default tenant
INSERT OR IGNORE INTO tenants (id, name, slug, description)
VALUES ('default', 'Staging System', 'system', 'Default staging tenant');

-- Super admin — upsert, because migration 0002 pre-seeds id='admin' with a
-- placeholder password_hash. We must overwrite it to make the account usable.
INSERT INTO users (id, email, password_hash, name, role, tenant_id)
VALUES ('admin', '${ADMIN_EMAIL}', '${ADMIN_PASSWORD_HASH}', 'Staging Admin', 'super_admin', NULL)
ON CONFLICT(id) DO UPDATE SET
  email = excluded.email,
  password_hash = excluded.password_hash,
  name = excluded.name,
  role = excluded.role,
  tenant_id = excluded.tenant_id;

-- Partner — role 'user' in the default tenant so eval picks attribute to a
-- distinct evaluator_user_id from the admin. Upsert so re-runs are idempotent.
INSERT INTO users (id, email, password_hash, name, role, tenant_id)
VALUES ('partner', '${PARTNER_EMAIL}', '${PARTNER_PASSWORD_HASH}', 'Staging Partner', 'user', 'default')
ON CONFLICT(id) DO UPDATE SET
  email = excluded.email,
  password_hash = excluded.password_hash,
  name = excluded.name,
  role = excluded.role,
  tenant_id = excluded.tenant_id;

-- Default site settings
INSERT OR IGNORE INTO site_settings (key, value, group_name) VALUES ('site_name', 'Dox (Staging)', 'general');
INSERT OR IGNORE INTO site_settings (key, value, group_name) VALUES ('max_file_size_mb', '100', 'uploads');
INSERT OR IGNORE INTO site_settings (key, value, group_name) VALUES ('allowed_file_types', '["pdf","doc","docx","xls","xlsx","csv","txt","png","jpg","jpeg"]', 'uploads');
SQL

npx wrangler d1 execute "$STAGING_DB" --remote --file="$TMPFILE" >/dev/null

# Persist credentials locally (gitignored). Overwrite any previous run.
cat > STAGING_CREDENTIALS.md <<EOF
# Staging Credentials

Generated by \`bin/seed-staging\`. Do not commit this file.

- URL: https://doc-upload-site-staging.pages.dev

## Admin (super_admin)

- Email: ${ADMIN_EMAIL}
- Password: ${ADMIN_PASSWORD}

## Partner (user, default tenant) — for separate A/B eval attribution

- Email: ${PARTNER_EMAIL}
- Password: ${PARTNER_PASSWORD}

The Cloudflare Pages project, D1 (doc-upload-db-staging), and R2
(doc-upload-files-staging) are fully isolated from production.

Re-run \`bin/seed-staging\` to rotate these credentials.
EOF
chmod 600 STAGING_CREDENTIALS.md

echo "Staging seed complete."
echo "Credentials written to: STAGING_CREDENTIALS.md (gitignored)"
