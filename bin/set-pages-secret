#!/usr/bin/env bash
# Set (or update) a secret on a Cloudflare Pages project.
# Wrapper around `wrangler pages secret put` so we have a reproducible,
# script-first path for managing per-environment secrets.
#
# Usage:
#   bin/set-pages-secret <pages-project-name> <secret-name> [secret-value]
#
# If <secret-value> is omitted, the value is read from stdin. Either way
# it is piped into wrangler — never echoed back. Wrangler overwrites an
# existing secret of the same name, so this is idempotent.
#
# Examples:
#   echo "$VALUE" | bin/set-pages-secret doc-upload-site-staging FOO
#   bin/set-pages-secret doc-upload-site-staging FOO "$VALUE"
set -euo pipefail
cd "$(dirname "$0")/.."

if [ "$#" -lt 2 ] || [ "$#" -gt 3 ]; then
  echo "Usage: $0 <pages-project-name> <secret-name> [secret-value]" >&2
  exit 1
fi

PROJECT="$1"
SECRET_NAME="$2"

if [ "$#" -eq 3 ]; then
  SECRET_VALUE="$3"
else
  # Read from stdin (single line; trailing newline stripped).
  if [ -t 0 ]; then
    echo "Reading secret value from stdin (press Ctrl-D to end)..." >&2
  fi
  SECRET_VALUE="$(cat)"
fi

# Load CLOUDFLARE_API_TOKEN / ACCOUNT_ID from .dev.vars if present so the
# call works the same way as bin/deploy-staging.
if [ -f .dev.vars ]; then
  set -a
  # shellcheck disable=SC1091
  source .dev.vars
  set +a
fi

# Pipe the value into wrangler so it never appears in process args / ps.
printf '%s' "$SECRET_VALUE" | npx wrangler pages secret put "$SECRET_NAME" --project-name "$PROJECT"

echo "Set ${SECRET_NAME} on ${PROJECT}"
