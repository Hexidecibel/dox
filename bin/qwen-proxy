#!/usr/bin/env node
const http = require('node:http');
const fs = require('node:fs');
const path = require('node:path');

const ROOT = path.resolve(__dirname, '..');
const SECRET_FILE = path.join(ROOT, '.qwen-proxy-secret');
const PORT = parseInt(process.env.QWEN_PROXY_PORT || '9601', 10);
const GPU_HOST = process.env.QWEN_GPU_HOST || '192.168.1.67';
const GPU_PORT = 9600;
const LOCAL_PORT = 9600;
const CONNECT_TIMEOUT = 2000;
const REQUEST_TIMEOUT = 310000; // 310s — long enough for big XLSX extraction chunks (~90-130s)
const TARGET = 'http://127.0.0.1:9600';

function getSecret() {
  if (process.env.QWEN_PROXY_SECRET) return process.env.QWEN_PROXY_SECRET;
  try {
    return fs.readFileSync(SECRET_FILE, 'utf8').trim();
  } catch {
    const secret = require('node:crypto').randomBytes(32).toString('hex');
    fs.writeFileSync(SECRET_FILE, secret + '\n', { mode: 0o600 });
    return secret;
  }
}

const SECRET = getSecret();

const server = http.createServer((req, res) => {
  const auth = req.headers['authorization'] || '';
  if (auth !== `Bearer ${SECRET}`) {
    res.writeHead(401, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ error: 'Unauthorized' }));
    return;
  }

  // Build forwarded headers, stripping Authorization
  const fwdHeaders = { ...req.headers };
  delete fwdHeaders['authorization'];
  delete fwdHeaders['host'];

  const url = new URL(req.url, TARGET);
  const reqPath = url.pathname + url.search;

  // Collect request body (we may need to send it twice)
  const bodyChunks = [];
  req.on('data', (chunk) => bodyChunks.push(chunk));
  req.on('end', () => {
    const body = Buffer.concat(bodyChunks);

    function sendTo(hostname, port, label, onError) {
      let connected = false;
      const proxyReq = http.request(
        {
          hostname,
          port,
          path: reqPath,
          method: req.method,
          headers: fwdHeaders,
          // For GPU: start with a short connect timeout, swap to REQUEST_TIMEOUT once connected.
          // For CPU fallback: use REQUEST_TIMEOUT immediately.
          timeout: hostname === GPU_HOST ? CONNECT_TIMEOUT : REQUEST_TIMEOUT,
        },
        (proxyRes) => {
          console.log(`[${label}] ${req.method} ${reqPath} -> ${proxyRes.statusCode}`);
          res.writeHead(proxyRes.statusCode, proxyRes.headers);
          proxyRes.pipe(res, { end: true });
        }
      );

      proxyReq.on('timeout', () => {
        if (!connected) {
          // Connect-phase timeout — try the fallback (or 502 if no fallback)
          proxyReq.destroy(new Error('connect timeout'));
        } else {
          // Request-phase timeout — return 504 cleanly instead of hanging
          console.error(`[${label}] request timeout after ${REQUEST_TIMEOUT}ms`);
          proxyReq.destroy(new Error('request timeout'));
          if (!res.headersSent) {
            res.writeHead(504, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'Gateway Timeout', detail: `upstream ${label} exceeded ${REQUEST_TIMEOUT}ms` }));
          }
        }
      });

      proxyReq.on('error', (err) => {
        console.error(`[${label}] ${err.message}`);
        if (!connected && onError) {
          onError();
        } else if (!res.headersSent) {
          res.writeHead(502, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Bad Gateway', detail: err.message }));
        }
      });

      // Once the socket connects, switch to the long request timeout.
      proxyReq.on('socket', (socket) => {
        socket.on('connect', () => {
          connected = true;
          proxyReq.setTimeout(REQUEST_TIMEOUT);
        });
      });

      proxyReq.end(body);
    }

    // Try GPU first, fall back to local CPU
    sendTo(GPU_HOST, GPU_PORT, 'gpu', () => {
      sendTo('127.0.0.1', LOCAL_PORT, 'cpu');
    });
  });
});

// Inbound timeouts — must be long enough for big XLSX extraction chunks (~90-130s).
server.setTimeout(REQUEST_TIMEOUT);
server.requestTimeout = REQUEST_TIMEOUT;
server.headersTimeout = REQUEST_TIMEOUT;
server.keepAliveTimeout = REQUEST_TIMEOUT + 10000; // slightly longer than requestTimeout per Node docs

server.listen(PORT, () => {
  console.log(`Qwen auth proxy listening on port ${PORT}`);
  console.log(`GPU backend: ${GPU_HOST}:${GPU_PORT} (${CONNECT_TIMEOUT}ms connect, ${REQUEST_TIMEOUT}ms request)`);
  console.log(`CPU backend: 127.0.0.1:${LOCAL_PORT} (fallback)`);
  console.log(`Secret: ${SECRET}`);
});
