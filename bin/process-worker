#!/usr/bin/env node

/**
 * Dox Document Process Worker
 *
 * Polls the dox API for queued documents, extracts text, calls Qwen for field
 * extraction, and posts results back. Runs locally as a daemon — no CF Worker
 * time limits.
 *
 * Config (environment variables):
 *   DOX_API_URL   — defaults to https://supdox.com
 *   DOX_API_KEY   — required, API key for auth (X-API-Key header)
 *   QWEN_URL      — defaults to http://127.0.0.1:9600
 *   QWEN_SECRET   — optional, Bearer token for Qwen auth proxy
 *   POLL_INTERVAL  — defaults to 3000 (ms)
 */

const { execFileSync } = require('child_process');
const os = require('os');
const path = require('path');
const fs = require('fs');
const { Agent } = require('undici');

// Increase headers timeout for slow LLM inference (default is 300s, we need 15min)
const llmDispatcher = new Agent({
  headersTimeout: 900_000,   // 15 minutes
  bodyTimeout: 900_000,      // 15 minutes
  connectTimeout: 30_000,    // 30 seconds
});

const DOX_API_URL = (process.env.DOX_API_URL || 'https://supdox.com').replace(/\/+$/, '');
const DOX_API_KEY = process.env.DOX_API_KEY || '';
const QWEN_URL = (process.env.QWEN_URL || 'http://127.0.0.1:9600').replace(/\/+$/, '');
const QWEN_SECRET = process.env.QWEN_SECRET || '';
const POLL_INTERVAL = parseInt(process.env.POLL_INTERVAL || '3000', 10);

if (!DOX_API_KEY) {
  console.error('Error: DOX_API_KEY environment variable is required');
  console.error('Create an API key in dox admin, then set DOX_API_KEY=dox_sk_...');
  process.exit(1);
}

const headers = {
  'X-API-Key': DOX_API_KEY,
  'Content-Type': 'application/json',
};

let processing = false;

async function poll() {
  if (processing) return; // skip if still working on previous batch
  processing = true;

  try {
    // Reset stale "processing" items (stuck for >10 min)
    try {
      const staleRes = await fetch(
        `${DOX_API_URL}/api/queue?processing_status=processing&limit=10`,
        { headers }
      );
      if (staleRes.ok) {
        const staleData = await staleRes.json();
        for (const item of (staleData.items || [])) {
          const updatedAt = new Date(item.created_at).getTime();
          if (Date.now() - updatedAt > 10 * 60 * 1000) {
            console.log(`Resetting stale item: ${item.file_name} (${item.id})`);
            await postResults(item.id, { processing_status: 'queued', error_message: null });
          }
        }
      }
    } catch (err) {
      console.warn('Staleness check failed:', err.message);
    }

    const res = await fetch(
      `${DOX_API_URL}/api/queue?processing_status=queued&limit=1`,
      { headers }
    );

    if (!res.ok) {
      const text = await res.text().catch(() => '');
      console.error(`Poll failed: ${res.status} ${text.substring(0, 200)}`);
      return;
    }

    const data = await res.json();
    const items = data.items || [];

    for (const item of items) {
      await processItem(item);
    }
  } catch (err) {
    console.error('Poll error:', err.message);
  } finally {
    processing = false;
  }
}

async function postResults(id, body) {
  const res = await fetch(`${DOX_API_URL}/api/queue/${id}/results`, {
    method: 'PUT',
    headers,
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const text = await res.text().catch(() => '');
    console.error(`Failed to post results for ${id}: ${res.status} ${text.substring(0, 200)}`);
  }
}

/**
 * OCR fallback for scanned/image-based PDFs.
 * Uses pdftoppm (poppler) to render pages as images, then tesseract for OCR.
 * Returns extracted text or null if tools aren't available.
 */
function ocrPdf(pdfBuffer) {
  // Check that required tools exist
  try {
    execFileSync('which', ['pdftoppm'], { stdio: 'pipe' });
    execFileSync('which', ['tesseract'], { stdio: 'pipe' });
  } catch {
    console.warn('  OCR unavailable: pdftoppm or tesseract not installed');
    return null;
  }

  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'dox-ocr-'));
  try {
    const pdfPath = path.join(tmpDir, 'input.pdf');
    fs.writeFileSync(pdfPath, Buffer.from(pdfBuffer));

    // Render PDF pages to grayscale PGM images at 300 DPI
    execFileSync('pdftoppm', ['-gray', '-r', '300', pdfPath, path.join(tmpDir, 'page')], {
      timeout: 30_000,
      stdio: 'pipe',
    });

    // Find generated page images and OCR each
    const pageFiles = fs.readdirSync(tmpDir)
      .filter(f => f.startsWith('page') && (f.endsWith('.pgm') || f.endsWith('.ppm')))
      .sort();

    if (pageFiles.length === 0) {
      console.warn('  OCR: pdftoppm produced no images');
      return null;
    }

    const texts = [];
    for (const pageFile of pageFiles) {
      try {
        const pagePath = path.join(tmpDir, pageFile);

        // Auto-rotate page if needed
        detectAndRotateImage(pagePath);

        // --psm 1 = auto page segmentation with OSD (handles rotated pages)
        const result = execFileSync('tesseract', [
          pagePath, 'stdout', '--psm', '1'
        ], { timeout: 60_000, stdio: ['pipe', 'pipe', 'pipe'] });
        texts.push(result.toString('utf-8'));
      } catch (err) {
        console.warn(`  OCR: tesseract failed on ${pageFile}: ${err.message}`);
      }
    }

    const combined = texts.join('\n\n').trim();
    return combined.length > 0 ? combined : null;
  } finally {
    // Clean up temp files
    try {
      for (const f of fs.readdirSync(tmpDir)) {
        fs.unlinkSync(path.join(tmpDir, f));
      }
      fs.rmdirSync(tmpDir);
    } catch { /* best-effort cleanup */ }
  }
}

/**
 * Detect orientation of an image using tesseract OSD and rotate if needed.
 * Uses ImageMagick (convert or magick) for rotation.
 * Returns the rotation angle applied (0 if none).
 */
function detectAndRotateImage(imagePath) {
  try {
    // --psm 0 = orientation and script detection only
    const osdOutput = execFileSync('tesseract', [
      imagePath, 'stdout', '--psm', '0'
    ], { timeout: 30_000, stdio: ['pipe', 'pipe', 'pipe'] }).toString('utf-8');

    // Parse rotation angle from OSD output
    // Output looks like: "Rotate: 90" or "Orientation in degrees: 90"
    const rotateMatch = osdOutput.match(/Rotate:\s*(\d+)/i) ||
                        osdOutput.match(/Orientation in degrees:\s*(\d+)/i);
    const rotation = rotateMatch ? parseInt(rotateMatch[1], 10) : 0;

    if (rotation > 0 && rotation !== 360) {
      console.log(`  Detected rotation: ${rotation}° — auto-correcting`);
      // Use ImageMagick to rotate
      try {
        execFileSync('convert', [imagePath, '-rotate', String(rotation), imagePath], {
          timeout: 30_000,
          stdio: 'pipe',
        });
        return rotation;
      } catch (err) {
        // Try 'magick' command (ImageMagick v7)
        try {
          execFileSync('magick', [imagePath, '-rotate', String(rotation), imagePath], {
            timeout: 30_000,
            stdio: 'pipe',
          });
          return rotation;
        } catch {
          console.warn(`  ImageMagick not available, skipping rotation`);
        }
      }
    }
    return 0;
  } catch (err) {
    // OSD detection failed (common with non-text images)
    return 0;
  }
}

async function fetchExtractionExamples(tenantId, documentTypeId, supplier) {
  const params = new URLSearchParams();
  if (documentTypeId) params.set('document_type_id', documentTypeId);
  if (tenantId) params.set('tenant_id', tenantId);

  try {
    const res = await fetch(
      `${DOX_API_URL}/api/extraction-examples?${params.toString()}&limit=5`,
      { headers }
    );
    if (!res.ok) return [];
    const data = await res.json();
    let examples = data.examples || [];

    // Prefer examples from same supplier
    if (supplier) {
      const supplierExamples = examples.filter(e =>
        e.supplier && e.supplier.toLowerCase().includes(supplier.toLowerCase())
      );
      if (supplierExamples.length > 0) {
        examples = supplierExamples;
      }
    }

    // Return top 3 by score (highest corrections first)
    return examples
      .sort((a, b) => (b.score || 0) - (a.score || 0))
      .slice(0, 3);
  } catch {
    return [];
  }
}

async function processItem(item) {
  const startTime = Date.now();
  console.log(`Processing ${item.file_name} (${item.id})...`);

  try {
    // Mark as processing
    await postResults(item.id, { processing_status: 'processing' });

    // Download file (with retry)
    let fileBuffer;
    for (let attempt = 1; attempt <= 3; attempt++) {
      try {
        const fileRes = await fetch(`${DOX_API_URL}/api/queue/${item.id}/file`, {
          headers: { 'X-API-Key': DOX_API_KEY },
        });
        if (!fileRes.ok) {
          throw new Error(`File download failed: ${fileRes.status}`);
        }
        fileBuffer = await fileRes.arrayBuffer();
        break;
      } catch (err) {
        if (attempt === 3) throw err;
        console.warn(`  Retry ${attempt}/3 for ${item.file_name}: ${err.message}`);
        await new Promise(r => setTimeout(r, 2000 * attempt));
      }
    }

    // Extract text based on mime type
    let text = null;

    // Keep a copy of fileBuffer for OCR fallback (unpdf may detach the ArrayBuffer)
    const fileBufferCopy = fileBuffer.slice(0);

    if (item.mime_type === 'application/pdf') {
      try {
        const { extractText } = await import('unpdf');
        const result = await extractText(new Uint8Array(fileBuffer), { mergePages: true });
        text = result.text?.substring(0, 100000) || null;
      } catch (err) {
        console.warn(`PDF extraction failed for ${item.file_name}:`, err.message);
      }

      // Check if unpdf output is garbled (columns merged without whitespace)
      if (text && text.trim().length > 0 && isTextGarbled(text)) {
        console.log(`  Text looks garbled (avg word len too high), trying OCR for ${item.file_name}...`);
        text = null; // fall through to OCR path below
      }

      // OCR fallback for scanned/image-based PDFs
      if (!text || text.trim().length === 0) {
        console.log(`  No text from unpdf, trying OCR for ${item.file_name}...`);
        text = ocrPdf(fileBufferCopy);
        if (text) {
          console.log(`  OCR extracted ${text.length} chars`);
          text = text.substring(0, 100000);
        }
      }
    } else if (
      item.mime_type === 'text/plain' ||
      item.mime_type === 'text/csv' ||
      item.mime_type === 'application/json'
    ) {
      text = new TextDecoder().decode(new Uint8Array(fileBuffer)).substring(0, 100000);
    } else if (item.mime_type === 'image/png' || item.mime_type === 'image/jpeg' || item.mime_type === 'image/jpg') {
      // OCR standalone images via tesseract
      try {
        const ext = item.mime_type === 'image/png' ? 'png' : 'jpg';
        const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'dox-ocr-'));
        const imgPath = path.join(tmpDir, `image.${ext}`);
        fs.writeFileSync(imgPath, Buffer.from(fileBuffer));

        // Auto-rotate image if needed before OCR
        detectAndRotateImage(imgPath);

        try {
          const result = execFileSync('tesseract', [
            imgPath, 'stdout', '--psm', '1'
          ], { timeout: 60_000, stdio: ['pipe', 'pipe', 'pipe'] });
          text = result.toString('utf-8').trim();
          if (text) {
            console.log(`  OCR extracted ${text.length} chars from image`);
            text = text.substring(0, 100000);
          }
        } catch (err) {
          console.warn(`  OCR failed for ${item.file_name}: ${err.message}`);
        }

        // Cleanup
        try {
          fs.unlinkSync(imgPath);
          fs.rmdirSync(tmpDir);
        } catch { /* best-effort */ }
      } catch (err) {
        console.warn(`  Image OCR setup failed: ${err.message}`);
      }
    }

    if (!text || text.trim().length === 0) {
      await postResults(item.id, {
        processing_status: 'error',
        error_message: `Could not extract text from ${item.mime_type} file. ${item.mime_type.startsWith('image/') ? 'OCR failed or produced no text.' : 'Unsupported file format for text extraction.'}`,
      });
      console.log(`  Skipped ${item.file_name}: no text extracted`);
      return;
    }

    // Trim text for LLM — 6K covers key fields on first 1-2 pages
    const llmText = text.substring(0, 6000);

    // Try to guess supplier from filename for better example matching
    let guessedSupplier = null;
    const supplierMatch = item.file_name.match(/^[\(\d\)\s]*([A-Za-z][A-Za-z\s&.]+?)[\s-]+(COA|BOL|SDS|cert|lot|spec)/i);
    if (supplierMatch) {
      guessedSupplier = supplierMatch[1].trim();
    }

    // Fetch few-shot examples for this tenant/doctype
    let examples = [];
    try {
      examples = await fetchExtractionExamples(item.tenant_id, item.document_type_id, guessedSupplier);
      if (examples.length > 0) {
        console.log(`  Using ${examples.length} few-shot example(s) for prompt`);
      }
    } catch {
      // Non-critical — continue without examples
    }

    // Call Qwen (with retry + 5 min timeout for cold starts)
    let qwenData;
    for (let attempt = 1; attempt <= 2; attempt++) {
      try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 1_800_000); // 30 min
        const qwenRes = await fetch(`${QWEN_URL}/v1/chat/completions`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            ...(QWEN_SECRET ? { Authorization: `Bearer ${QWEN_SECRET}` } : {}),
          },
          signal: controller.signal,
          dispatcher: llmDispatcher,
          body: JSON.stringify({
            model: 'Qwen3-5-35B-A3B',
            temperature: 0,
            max_tokens: 4096,
            messages: [
              { role: 'system', content: buildPrompt(examples) },
              {
                role: 'user',
                content: `<document>\n${llmText}\n</document>\n\nExtract ALL structured data from this document. Return JSON only. /no_think`,
              },
            ],
          }),
        });
        clearTimeout(timeout);
        if (!qwenRes.ok) {
          const errText = await qwenRes.text().catch(() => '');
          throw new Error(`Qwen HTTP ${qwenRes.status}: ${errText.substring(0, 200)}`);
        }
        qwenData = await qwenRes.json();
        break;
      } catch (err) {
        if (attempt === 2) throw new Error(`Qwen call failed: ${err.message}`);
        console.warn(`  Qwen retry ${attempt}/2 for ${item.file_name}: ${err.message}`);
        // Wait 60s on retry — give model time to load
        console.warn('  Waiting 60s for model to load...');
        await new Promise(r => setTimeout(r, 60_000));
      }
    }
    const content = qwenData.choices?.[0]?.message?.content || '';
    console.log(`  Qwen response (${content.length} chars): ${content.substring(0, 200)}...`);

    // Parse response
    const parsed = parseExtraction(content);

    // Canonicalize field names and detect supplier
    const canonicalized = canonicalizeFields(parsed.fields || {});
    if (canonicalized.supplier_name && isLikelyAddress(canonicalized.supplier_name)) {
      canonicalized.supplier_name = null;
    }
    parsed.fields = canonicalized;
    const supplier = canonicalized.supplier_name || null;

    // Compute confidence score
    const confidenceScore = computeConfidenceScore(parsed.confidence, parsed.fields || {}, parsed.tables || []);

    // Resolve document type if AI guessed one and queue item has no doc type set
    let resolvedDocTypeId = item.document_type_id || null;
    const docTypeGuess = parsed.documentType || null;

    if (docTypeGuess && !resolvedDocTypeId) {
      try {
        resolvedDocTypeId = await fuzzyMatchDocType(docTypeGuess, item.tenant_id);
      } catch (err) {
        console.warn(`  Doc type matching failed:`, err.message);
      }
    }

    // Post results
    const resultBody = {
      processing_status: 'ready',
      extracted_text: text.substring(0, 100000),
      ai_fields: JSON.stringify(parsed.fields || {}),
      ai_confidence: parsed.confidence || 'low',
      confidence_score: confidenceScore,
      product_names: JSON.stringify(parsed.products || []),
      tables: JSON.stringify(parsed.tables || []),
      summary: parsed.summary || '',
      supplier: supplier,
      document_type_guess: docTypeGuess,
    };

    if (resolvedDocTypeId && !item.document_type_id) {
      resultBody.document_type_id = resolvedDocTypeId;
    }

    await postResults(item.id, resultBody);

    const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
    console.log(`  Done: ${item.file_name} (${Math.round(confidenceScore * 100)}% confidence, ${elapsed}s)`);
  } catch (err) {
    console.error(`  Error processing ${item.file_name}:`, err.message);
    await postResults(item.id, {
      processing_status: 'error',
      error_message: err.message,
    }).catch(() => {});
  }
}

// === Field canonicalization ===

const FIELD_ALIASES = {
  supplier_name: ['supplier', 'vendor', 'manufacturer', 'company', 'from', 'shipped_by'],
  customer_name: ['customer', 'sold_to', 'ship_to', 'buyer', 'consignee'],
  lot_number: ['lot_no', 'lot_num', 'lot', 'batch_number', 'batch_no', 'batch', 'run_number', 'lot_code'],
  po_number: ['po', 'purchase_order', 'purchase_order_number', 'po_no'],
  product_name: ['product', 'item', 'material', 'description', 'item_description'],
  product_code: ['item_code', 'sku', 'material_code', 'item_number', 'item_no'],
  expiration_date: ['exp_date', 'best_by', 'use_by', 'best_before', 'sell_by', 'bb_date'],
  code_date: ['production_date', 'pack_date', 'mfg_date', 'manufacture_date', 'date_of_manufacture'],
  ship_date: ['shipping_date', 'date_shipped'],
  net_weight: ['weight', 'net_wt'],
  order_number: ['order_no', 'sales_order', 'reference_number', 'ref_number'],
  grade: ['quality_grade', 'usda_grade'],
  plant_number: ['plant_no', 'facility_number', 'facility_id', 'plant_id'],
};

function canonicalizeFields(fields) {
  const reverseMap = {};
  for (const [canonical, aliases] of Object.entries(FIELD_ALIASES)) {
    for (const alias of aliases) {
      reverseMap[alias] = canonical;
    }
  }
  const result = {};
  for (const [key, value] of Object.entries(fields)) {
    const canonical = reverseMap[key] || key;
    if (!(canonical in result) || result[canonical] == null) {
      result[canonical] = value;
    }
  }
  return result;
}

// === Address detection ===

function isLikelyAddress(value) {
  if (!value || typeof value !== 'string') return false;
  const v = value.trim();
  const streetPattern = /^\d+\s+(N\.?|S\.?|E\.?|W\.?|North|South|East|West|Main)\b/i;
  const unitStreetPattern = /^[A-Z0-9#]+\s+\d+\s+\w/i;
  const stateZipPattern = /\b[A-Z]{2}\s+\d{5}(-\d{4})?\b/;
  const streetSuffixes = /\b(Street|St\.?|Avenue|Ave\.?|Boulevard|Blvd\.?|Road|Rd\.?|Drive|Dr\.?|Lane|Ln\.?|Way|Court|Ct\.?|Place|Pl\.?)\b/i;
  if ((streetPattern.test(v) || unitStreetPattern.test(v)) && (stateZipPattern.test(v) || streetSuffixes.test(v))) {
    return true;
  }
  if (stateZipPattern.test(v) && streetSuffixes.test(v)) {
    return true;
  }
  return false;
}

// === Garbled text detection ===

function isTextGarbled(text) {
  if (!text || text.length < 100) return false;
  const words = text.split(/\s+/).filter(w => w.length > 0);
  if (words.length === 0) return false;
  const avgWordLen = words.reduce((s, w) => s + w.length, 0) / words.length;
  const whitespaceRatio = (text.match(/\s/g) || []).length / text.length;
  // Long average words + low whitespace = column-merged garbage from bad PDF extraction
  return avgWordLen > 15 || whitespaceRatio < 0.08;
}

// === Document type fuzzy matching ===

async function fuzzyMatchDocType(guess, tenantId) {
  const res = await fetch(
    `${DOX_API_URL}/api/document-types?tenant_id=${encodeURIComponent(tenantId)}&active=1`,
    { headers }
  );
  if (!res.ok) return null;

  const data = await res.json();
  const docTypes = data.documentTypes || [];
  if (docTypes.length === 0) return null;

  const normalize = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
  const guessNorm = normalize(guess);

  // Exact name/slug match
  for (const dt of docTypes) {
    if (normalize(dt.name) === guessNorm || dt.slug === guessNorm.replace(/\s+/g, '-')) {
      return dt.id;
    }
  }

  // Substring match (either direction)
  for (const dt of docTypes) {
    const dtNorm = normalize(dt.name);
    if (guessNorm.includes(dtNorm) || dtNorm.includes(guessNorm)) {
      return dt.id;
    }
  }

  // Acronym match: "COA" matches "Certificate of Analysis"
  for (const dt of docTypes) {
    const dtNorm = normalize(dt.name);
    const acronym = dtNorm.split(' ').map(w => w[0]).join('');
    if (acronym === guessNorm || guessNorm === acronym) {
      return dt.id;
    }
  }

  return null;
}

// === Prompt (same content as functions/lib/llm.ts) ===

const BASE_PROMPT = `You are a document data extraction assistant specializing in supply chain and compliance documents including Certificates of Analysis (COAs), Bills of Lading, Spec Sheets, Safety Data Sheets, and invoices.

DOCUMENT TYPES:
- Certificate of Analysis (COA): Lab/QA results proving a product batch meets specifications. Structure: header info (supplier, customer, dates, lot) + test results table + approval.
- Bill of Lading (BOL): Shipping document with carrier, origin, destination, weights.
- Spec Sheet: Product specification with allowable ranges for tests.
- Invoice / PO: Purchase order or invoice with line items, quantities, prices.
- Safety Data Sheet (SDS): Chemical safety information.

FIELD EXTRACTION RULES:
1. Use these EXACT canonical field names (snake_case):
   - supplier_name — company/organization name that produced/shipped the product (NOT a street address — if only an address is visible with no company name, set to null)
   - customer_name — company receiving the product
   - product_name — full product name (e.g., "Unsalted Sweet Cream Butter 68#")
   - product_code — supplier's internal product/item code or SKU
   - lot_number — lot, batch, or run number
   - po_number — purchase order number
   - code_date — production/pack/code date
   - expiration_date — expiration, best-by, use-by, or sell-by date
   - ship_date — date shipped
   - grade — quality grade (e.g., "Grade A", "Grade AA", "US Extra")
   - plant_number — facility ID or plant number
   - net_weight — net weight with units
   - order_number — sales order or reference number

2. For dates: normalize to YYYY-MM-DD. Two-digit years mean 2000s (e.g., '26 = 2026, 03/08/26 = 2026-03-08). Julian dates (e.g., "6094") mean day 094 of 2026 — convert when identifiable. If ambiguous, keep as-is.

3. DO NOT include: addresses, phone/fax/email, page numbers, print dates, header/footer boilerplate, signatures, titles, disclaimers, individual test values (those go in tables).

TABLE EXTRACTION RULES:
1. Extract ALL tabular data found in the document. Preserve every column present — do not drop columns.
2. Name tables descriptively: "test_results", "line_items", "physical_properties", "microbiological_analysis", "sensory_analysis", etc.
3. Use the column headers exactly as they appear in the document. If no headers exist, infer them from context.
4. For COA test results, common columns include: test, test_method, unit_of_measure, specification, result, units, pass_fail — but extract whatever columns are present.
5. Preserve units (CFU/mL, %, mg/kg, etc.) and pass/fail values as written.
6. Multiple distinct tables in the document → separate entries for each (e.g., physical tests and microbiological tests should be separate tables).
7. Keep row order as it appears in the document.

OCR / SCANNED DOCUMENT HANDLING:
- If text appears garbled, do your best but set _confidence to "low"
- Common OCR errors: l↔1, O↔0, rn↔m. Infer correct values from context.
- Partially readable values: include what you can and append "(?)".

Return JSON with:
{
  "fields": { ... },
  "tables": [{ "name": "string", "headers": [...], "rows": [[...]] }],
  "products": ["product name 1", ...],
  "summary": "one-sentence description",
  "_confidence": "high" | "medium" | "low",
  "document_type": "Certificate of Analysis" | "Bill of Lading" | etc.
}`;

const DAIRY_FOOD_INDUSTRY_PROMPT = `
INDUSTRY CONTEXT — Dairy & Food:
- Common COA tests: Standard Plate Count (SPC), coliform, E. coli, yeast & mold, somatic cell count, butterfat %, moisture %, pH, acidity, temperature
- Grade designations: Grade A, Grade AA, US Extra, USDA grades
- Plant/facility numbers: USDA plant numbers (e.g., "Plant 42-1234")
- Code dates may use Julian format (YDDD where Y=last digit of year, DDD=day)
- Net weights: common units are lbs, gallons, kg

EXAMPLE — Dairy COA extraction:
Input: "Darigold Inc. COA for Grade AA Butter 68#, Lot L26-0842, PO PO-44821, Packed 03/15/26, Best By 09/15/26, Plant 42-1234. Tests: Fat >80% result 81.2% Pass, Moisture <16% result 15.4% Pass, Coliform <10 CFU/g result <1 Pass, SPC <20000 CFU/g result 4500 Pass"

Output:
{
  "fields": {
    "supplier_name": "Darigold Inc.",
    "product_name": "Grade AA Butter 68#",
    "lot_number": "L26-0842",
    "po_number": "PO-44821",
    "code_date": "2026-03-15",
    "expiration_date": "2026-09-15",
    "grade": "Grade AA",
    "plant_number": "42-1234",
    "net_weight": "68 lbs"
  },
  "tables": [{
    "name": "test_results",
    "headers": ["test", "test_method", "specification", "result", "units", "pass_fail"],
    "rows": [
      ["Fat Content", "SMEDP 15.122", ">80%", "81.2", "%", "Pass"],
      ["Moisture", "SMEDP 15.122", "<16%", "15.4", "%", "Pass"],
      ["Coliform", "AOAC 989.10", "<10", "<1", "CFU/g", "Pass"],
      ["Standard Plate Count", "AOAC 989.10", "<20,000", "4,500", "CFU/g", "Pass"]
    ]
  }],
  "products": ["Grade AA Butter 68#"],
  "summary": "COA for Darigold Grade AA Butter lot L26-0842, all tests pass.",
  "_confidence": "high",
  "document_type": "Certificate of Analysis"
}`;

function buildPrompt(examples = []) {
  let prompt = BASE_PROMPT + '\n\n' + DAIRY_FOOD_INDUSTRY_PROMPT;

  if (examples.length > 0) {
    prompt += '\n\nPREVIOUS CORRECTIONS FOR THIS SUPPLIER/DOCUMENT TYPE:';
    prompt += '\nLearn from these past corrections. The "corrected" output is what the human verified as correct.\n';

    for (const ex of examples) {
      const inputSnippet = (ex.input_text || '').substring(0, 500);
      const corrected = ex.corrected_output || ex.ai_output || '{}';

      prompt += `\nExample input (truncated):\n${inputSnippet}\n`;
      prompt += `Corrected extraction:\n${corrected}\n`;
    }

    prompt += '\nUse these examples to guide your extraction. Match the field names and formatting from the corrections.';
  }

  return prompt;
}

// === Response parser (same logic as functions/lib/llm.ts) ===

function parseExtraction(content) {
  content = (content || '').trim();

  // Strip Qwen3 <think>...</think> blocks (thinking model artifacts)
  content = content.replace(/<think>[\s\S]*?<\/think>\s*/g, '').trim();

  // Strip markdown code fences
  const fenceMatch = content.match(/^```(?:json)?\s*\n?([\s\S]*?)\n?\s*```$/);
  if (fenceMatch) {
    content = fenceMatch[1].trim();
  }

  let parsed;
  try {
    parsed = JSON.parse(content);
  } catch {
    return { fields: {}, tables: [], products: [], summary: '', confidence: 'low' };
  }

  const products = Array.isArray(parsed.products) ? parsed.products : [];
  const confidence = ['high', 'medium', 'low'].includes(parsed._confidence) ? parsed._confidence : 'low';
  const tables = Array.isArray(parsed.tables) ? parsed.tables : [];
  const summary = typeof parsed.summary === 'string' ? parsed.summary : '';
  const documentType = typeof parsed.document_type === 'string' ? parsed.document_type : null;

  // Build fields
  const fields = {};
  const rawFields =
    typeof parsed.fields === 'object' && parsed.fields !== null && !Array.isArray(parsed.fields)
      ? parsed.fields
      : parsed;
  const reservedKeys = new Set(['fields', 'tables', 'products', 'summary', '_confidence', 'document_type']);

  for (const [key, value] of Object.entries(rawFields)) {
    if (!key.startsWith('_') && !reservedKeys.has(key)) {
      fields[key] = value === null || value === undefined ? null : String(value);
    }
  }

  return { fields: flattenFields(fields), tables, products, summary, confidence, documentType };
}

// === Flatten nested objects/arrays in extracted fields ===

function flattenFields(fields) {
  const result = {};
  for (const [key, value] of Object.entries(fields)) {
    if (value === null || value === undefined) {
      result[key] = null;
    } else if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
      result[key] = String(value);
    } else if (Array.isArray(value)) {
      // If array of simple values, join them
      if (value.every(v => typeof v === 'string' || typeof v === 'number')) {
        result[key] = value.join(', ');
      } else {
        // Complex array — stringify it
        result[key] = JSON.stringify(value);
      }
    } else if (typeof value === 'object') {
      // Flatten nested object: { customer: { name: "ACME", city: "LA" } }
      // becomes: { customer_name: "ACME", customer_city: "LA" }
      for (const [subKey, subValue] of Object.entries(value)) {
        if (subValue !== null && subValue !== undefined) {
          result[`${key}_${subKey}`] = typeof subValue === 'object' ? JSON.stringify(subValue) : String(subValue);
        }
      }
    }
  }
  return result;
}

// === Confidence score (same logic as functions/lib/confidence.ts) ===

function computeConfidenceScore(aiConfidence, extractedFields, tables = []) {
  // Lower base weights — LLM self-assessment is unreliable
  let score = aiConfidence === 'high' ? 0.85 : aiConfidence === 'medium' ? 0.55 : 0.25;

  const fields = extractedFields || {};
  const nonNullFields = Object.entries(fields).filter(([, v]) => v != null && String(v).trim() !== '');

  // Bonus for finding data (up to +0.08)
  score += Math.min(nonNullFields.length * 0.01, 0.08);

  // Reward key document fields being present (+0.02 each, up to +0.06)
  const keyFields = ['supplier_name', 'product_name', 'lot_number'];
  for (const key of keyFields) {
    if (fields[key] != null && String(fields[key]).trim() !== '') {
      score += 0.02;
    }
  }

  // Reward having at least one date field (+0.02)
  const hasDate = Object.entries(fields).some(
    ([k, v]) => k.includes('date') && v != null && String(v).trim() !== ''
  );
  if (hasDate) score += 0.02;

  // Reward having test results table with actual rows (+0.03)
  const hasTestResults = tables.some(
    t => t.rows && t.rows.length > 0 && t.headers && t.headers.length > 0
  );
  if (hasTestResults) score += 0.03;

  // Penalize date fields that don't look like dates (-0.08 each)
  for (const [key, value] of Object.entries(fields)) {
    if (value && key.includes('date')) {
      const v = String(value);
      const looksLikeDate =
        /\d{4}[-/]\d{1,2}[-/]\d{1,2}/.test(v) ||
        /\d{1,2}[-/]\d{1,2}[-/]\d{2,4}/.test(v);
      if (!looksLikeDate) {
        score -= 0.08;
      }
    }
  }

  // Penalize very short lot numbers (-0.05)
  const lotValue = fields['lot_number'];
  if (lotValue && String(lotValue).trim().length < 3) {
    score -= 0.05;
  }

  // Penalize uncertainty markers (-0.05 each)
  for (const [, value] of nonNullFields) {
    if (String(value).includes('(?)')) {
      score -= 0.05;
    }
  }

  return Math.max(0, Math.min(1, score));
}

