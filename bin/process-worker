#!/usr/bin/env node

/**
 * Dox Document Process Worker
 *
 * Polls the dox API for queued documents, extracts text, calls Qwen for field
 * extraction, and posts results back. Runs locally as a daemon — no CF Worker
 * time limits.
 *
 * Config (environment variables):
 *   DOX_API_URL   — defaults to https://dox.cush.rocks
 *   DOX_API_KEY   — required, API key for auth (X-API-Key header)
 *   QWEN_URL      — defaults to http://127.0.0.1:9600
 *   POLL_INTERVAL  — defaults to 3000 (ms)
 */

const { execFileSync } = require('child_process');
const os = require('os');
const path = require('path');
const fs = require('fs');

const DOX_API_URL = (process.env.DOX_API_URL || 'https://dox.cush.rocks').replace(/\/+$/, '');
const DOX_API_KEY = process.env.DOX_API_KEY || '';
const QWEN_URL = (process.env.QWEN_URL || 'http://127.0.0.1:9600').replace(/\/+$/, '');
const POLL_INTERVAL = parseInt(process.env.POLL_INTERVAL || '3000', 10);

if (!DOX_API_KEY) {
  console.error('Error: DOX_API_KEY environment variable is required');
  console.error('Create an API key in dox admin, then set DOX_API_KEY=dox_sk_...');
  process.exit(1);
}

const headers = {
  'X-API-Key': DOX_API_KEY,
  'Content-Type': 'application/json',
};

let processing = false;

async function poll() {
  if (processing) return; // skip if still working on previous batch
  processing = true;

  try {
    const res = await fetch(
      `${DOX_API_URL}/api/queue?processing_status=queued&limit=1`,
      { headers }
    );

    if (!res.ok) {
      const text = await res.text().catch(() => '');
      console.error(`Poll failed: ${res.status} ${text.substring(0, 200)}`);
      return;
    }

    const data = await res.json();
    const items = data.items || [];

    for (const item of items) {
      await processItem(item);
    }
  } catch (err) {
    console.error('Poll error:', err.message);
  } finally {
    processing = false;
  }
}

async function postResults(id, body) {
  const res = await fetch(`${DOX_API_URL}/api/queue/${id}/results`, {
    method: 'PUT',
    headers,
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const text = await res.text().catch(() => '');
    console.error(`Failed to post results for ${id}: ${res.status} ${text.substring(0, 200)}`);
  }
}

/**
 * OCR fallback for scanned/image-based PDFs.
 * Uses pdftoppm (poppler) to render pages as images, then tesseract for OCR.
 * Returns extracted text or null if tools aren't available.
 */
function ocrPdf(pdfBuffer) {
  // Check that required tools exist
  try {
    execFileSync('which', ['pdftoppm'], { stdio: 'pipe' });
    execFileSync('which', ['tesseract'], { stdio: 'pipe' });
  } catch {
    console.warn('  OCR unavailable: pdftoppm or tesseract not installed');
    return null;
  }

  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'dox-ocr-'));
  try {
    const pdfPath = path.join(tmpDir, 'input.pdf');
    fs.writeFileSync(pdfPath, Buffer.from(pdfBuffer));

    // Render PDF pages to grayscale PGM images at 300 DPI
    execFileSync('pdftoppm', ['-gray', '-r', '300', pdfPath, path.join(tmpDir, 'page')], {
      timeout: 30_000,
      stdio: 'pipe',
    });

    // Find generated page images and OCR each
    const pageFiles = fs.readdirSync(tmpDir)
      .filter(f => f.startsWith('page') && (f.endsWith('.pgm') || f.endsWith('.ppm')))
      .sort();

    if (pageFiles.length === 0) {
      console.warn('  OCR: pdftoppm produced no images');
      return null;
    }

    const texts = [];
    for (const pageFile of pageFiles) {
      try {
        // --psm 1 = auto page segmentation with OSD (handles rotated pages)
        const result = execFileSync('tesseract', [
          path.join(tmpDir, pageFile), 'stdout', '--psm', '1'
        ], { timeout: 60_000, stdio: ['pipe', 'pipe', 'pipe'] });
        texts.push(result.toString('utf-8'));
      } catch (err) {
        console.warn(`  OCR: tesseract failed on ${pageFile}: ${err.message}`);
      }
    }

    const combined = texts.join('\n\n').trim();
    return combined.length > 0 ? combined : null;
  } finally {
    // Clean up temp files
    try {
      for (const f of fs.readdirSync(tmpDir)) {
        fs.unlinkSync(path.join(tmpDir, f));
      }
      fs.rmdirSync(tmpDir);
    } catch { /* best-effort cleanup */ }
  }
}

async function processItem(item) {
  const startTime = Date.now();
  console.log(`Processing ${item.file_name} (${item.id})...`);

  try {
    // Mark as processing
    await postResults(item.id, { processing_status: 'processing' });

    // Download file (with retry)
    let fileBuffer;
    for (let attempt = 1; attempt <= 3; attempt++) {
      try {
        const fileRes = await fetch(`${DOX_API_URL}/api/queue/${item.id}/file`, {
          headers: { 'X-API-Key': DOX_API_KEY },
        });
        if (!fileRes.ok) {
          throw new Error(`File download failed: ${fileRes.status}`);
        }
        fileBuffer = await fileRes.arrayBuffer();
        break;
      } catch (err) {
        if (attempt === 3) throw err;
        console.warn(`  Retry ${attempt}/3 for ${item.file_name}: ${err.message}`);
        await new Promise(r => setTimeout(r, 2000 * attempt));
      }
    }

    // Extract text based on mime type
    let text = null;

    if (item.mime_type === 'application/pdf') {
      try {
        const { extractText } = await import('unpdf');
        const result = await extractText(new Uint8Array(fileBuffer), { mergePages: true });
        text = result.text?.substring(0, 100000) || null;
      } catch (err) {
        console.warn(`PDF extraction failed for ${item.file_name}:`, err.message);
      }

      // OCR fallback for scanned/image-based PDFs
      if (!text || text.trim().length === 0) {
        console.log(`  No text from unpdf, trying OCR for ${item.file_name}...`);
        text = ocrPdf(fileBuffer);
        if (text) {
          console.log(`  OCR extracted ${text.length} chars`);
          text = text.substring(0, 100000);
        }
      }
    } else if (
      item.mime_type === 'text/plain' ||
      item.mime_type === 'text/csv' ||
      item.mime_type === 'application/json'
    ) {
      text = new TextDecoder().decode(new Uint8Array(fileBuffer)).substring(0, 100000);
    }

    if (!text || text.trim().length === 0) {
      await postResults(item.id, {
        processing_status: 'error',
        error_message: 'Could not extract text from file',
      });
      console.log(`  Skipped ${item.file_name}: no text extracted`);
      return;
    }

    // Trim text for LLM — 4K chars is plenty for COAs/invoices
    const llmText = text.substring(0, 4000);

    // Call Qwen (with retry + 5 min timeout for cold starts)
    let qwenData;
    for (let attempt = 1; attempt <= 2; attempt++) {
      try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 300_000); // 5 min
        const qwenRes = await fetch(`${QWEN_URL}/v1/chat/completions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          signal: controller.signal,
          body: JSON.stringify({
            model: 'Qwen3-5-35B-A3B',
            temperature: 0,
            max_tokens: 1024,
            messages: [
              { role: 'system', content: buildPrompt() },
              {
                role: 'user',
                content: `<document>\n${llmText}\n</document>\n\nExtract the key structured data. Return JSON only. /no_think`,
              },
            ],
          }),
        });
        clearTimeout(timeout);
        if (!qwenRes.ok) {
          const errText = await qwenRes.text().catch(() => '');
          throw new Error(`Qwen HTTP ${qwenRes.status}: ${errText.substring(0, 200)}`);
        }
        qwenData = await qwenRes.json();
        break;
      } catch (err) {
        if (attempt === 2) throw new Error(`Qwen call failed: ${err.message}`);
        console.warn(`  Qwen retry ${attempt}/2 for ${item.file_name}: ${err.message}`);
        // Wait 60s on retry — give model time to load
        console.warn('  Waiting 60s for model to load...');
        await new Promise(r => setTimeout(r, 60_000));
      }
    }
    const content = qwenData.choices?.[0]?.message?.content || '';

    // Parse response
    const parsed = parseExtraction(content);

    // Detect supplier
    const supplierKeys = ['supplier_name', 'supplier', 'manufacturer', 'vendor', 'company', 'from'];
    const supplier = supplierKeys.map(k => parsed.fields?.[k]).find(v => v != null && String(v).trim() !== '') || null;

    // Compute confidence score
    const confidenceScore = computeConfidenceScore(parsed.confidence, parsed.fields || {});

    // Resolve document type if AI guessed one and queue item has no doc type set
    let resolvedDocTypeId = item.document_type_id || null;
    const docTypeGuess = parsed.documentType || null;

    if (docTypeGuess && !resolvedDocTypeId) {
      try {
        resolvedDocTypeId = await fuzzyMatchDocType(docTypeGuess, item.tenant_id);
      } catch (err) {
        console.warn(`  Doc type matching failed:`, err.message);
      }
    }

    // Post results
    const resultBody = {
      processing_status: 'ready',
      extracted_text: text.substring(0, 100000),
      ai_fields: JSON.stringify(parsed.fields || {}),
      ai_confidence: parsed.confidence || 'low',
      confidence_score: confidenceScore,
      product_names: JSON.stringify(parsed.products || []),
      tables: JSON.stringify(parsed.tables || []),
      summary: parsed.summary || '',
      supplier: supplier,
      document_type_guess: docTypeGuess,
    };

    if (resolvedDocTypeId && !item.document_type_id) {
      resultBody.document_type_id = resolvedDocTypeId;
    }

    await postResults(item.id, resultBody);

    const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
    console.log(`  Done: ${item.file_name} (${Math.round(confidenceScore * 100)}% confidence, ${elapsed}s)`);
  } catch (err) {
    console.error(`  Error processing ${item.file_name}:`, err.message);
    await postResults(item.id, {
      processing_status: 'error',
      error_message: err.message,
    }).catch(() => {});
  }
}

// === Document type fuzzy matching ===

async function fuzzyMatchDocType(guess, tenantId) {
  const res = await fetch(
    `${DOX_API_URL}/api/document-types?tenant_id=${encodeURIComponent(tenantId)}&active=1`,
    { headers }
  );
  if (!res.ok) return null;

  const data = await res.json();
  const docTypes = data.documentTypes || [];
  if (docTypes.length === 0) return null;

  const normalize = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
  const guessNorm = normalize(guess);

  // Exact name/slug match
  for (const dt of docTypes) {
    if (normalize(dt.name) === guessNorm || dt.slug === guessNorm.replace(/\s+/g, '-')) {
      return dt.id;
    }
  }

  // Substring match (either direction)
  for (const dt of docTypes) {
    const dtNorm = normalize(dt.name);
    if (guessNorm.includes(dtNorm) || dtNorm.includes(guessNorm)) {
      return dt.id;
    }
  }

  // Acronym match: "COA" matches "Certificate of Analysis"
  for (const dt of docTypes) {
    const dtNorm = normalize(dt.name);
    const acronym = dtNorm.split(' ').map(w => w[0]).join('');
    if (acronym === guessNorm || guessNorm === acronym) {
      return dt.id;
    }
  }

  return null;
}

// === Prompt (same logic as functions/lib/llm.ts) ===

function buildPrompt() {
  return [
    'You are a document data extraction assistant. Analyze the document and extract structured data.',
    '',
    'IMPORTANT RULES:',
    '1. Put test results, lab analyses, specifications, and any tabular data into "tables" — NOT as individual key-value fields.',
    '2. DO NOT include as fields:',
    '   - Page numbers, print dates, header/footer text',
    '   - Addresses, phone numbers, fax numbers, websites',
    '   - Boilerplate text, disclaimers, signatures',
    '   - Individual test values that belong in a results table',
    '3. DO include as fields:',
    '   - Document identifiers (lot numbers, PO numbers, order numbers, invoice numbers)',
    '   - Dates that matter (expiration, production, ship date, code date)',
    '   - Names (supplier, customer, product, manufacturer)',
    '   - Quantities, weights, descriptions',
    '   - Reference numbers, certifications',
    '',
    'Return a JSON object with:',
    '',
    '1. "fields": key-value pairs of meaningful document data. Use snake_case keys (e.g., "Lot Number" → "lot_number"). Set null for unclear values. ONLY include fields that a human would consider important business data.',
    '',
    '2. "tables": tabular data (test results, specs, line items). Each: { "name": "string", "headers": ["col1", "col2"], "rows": [["val1", "val2"]] }',
    '',
    '3. "products": array of product/item names found.',
    '',
    '4. "summary": one-sentence description of the document.',
    '',
    '5. "_confidence": "high", "medium", or "low"',
    '',
    '6. "document_type": a short label for what kind of document this is (e.g., "Certificate of Analysis", "Bill of Lading", "Safety Data Sheet", "Spec Sheet", "Invoice", "Purchase Order"). Use standard industry terminology.',
  ].join('\n');
}

// === Response parser (same logic as functions/lib/llm.ts) ===

function parseExtraction(content) {
  content = (content || '').trim();

  // Strip markdown code fences
  const fenceMatch = content.match(/^```(?:json)?\s*\n?([\s\S]*?)\n?\s*```$/);
  if (fenceMatch) {
    content = fenceMatch[1].trim();
  }

  let parsed;
  try {
    parsed = JSON.parse(content);
  } catch {
    return { fields: {}, tables: [], products: [], summary: '', confidence: 'low' };
  }

  const products = Array.isArray(parsed.products) ? parsed.products : [];
  const confidence = ['high', 'medium', 'low'].includes(parsed._confidence) ? parsed._confidence : 'low';
  const tables = Array.isArray(parsed.tables) ? parsed.tables : [];
  const summary = typeof parsed.summary === 'string' ? parsed.summary : '';
  const documentType = typeof parsed.document_type === 'string' ? parsed.document_type : null;

  // Build fields
  const fields = {};
  const rawFields =
    typeof parsed.fields === 'object' && parsed.fields !== null && !Array.isArray(parsed.fields)
      ? parsed.fields
      : parsed;
  const reservedKeys = new Set(['fields', 'tables', 'products', 'summary', '_confidence', 'document_type']);

  for (const [key, value] of Object.entries(rawFields)) {
    if (!key.startsWith('_') && !reservedKeys.has(key)) {
      fields[key] = value === null || value === undefined ? null : String(value);
    }
  }

  return { fields: flattenFields(fields), tables, products, summary, confidence, documentType };
}

// === Flatten nested objects/arrays in extracted fields ===

function flattenFields(fields) {
  const result = {};
  for (const [key, value] of Object.entries(fields)) {
    if (value === null || value === undefined) {
      result[key] = null;
    } else if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
      result[key] = String(value);
    } else if (Array.isArray(value)) {
      // If array of simple values, join them
      if (value.every(v => typeof v === 'string' || typeof v === 'number')) {
        result[key] = value.join(', ');
      } else {
        // Complex array — stringify it
        result[key] = JSON.stringify(value);
      }
    } else if (typeof value === 'object') {
      // Flatten nested object: { customer: { name: "ACME", city: "LA" } }
      // becomes: { customer_name: "ACME", customer_city: "LA" }
      for (const [subKey, subValue] of Object.entries(value)) {
        if (subValue !== null && subValue !== undefined) {
          result[`${key}_${subKey}`] = typeof subValue === 'object' ? JSON.stringify(subValue) : String(subValue);
        }
      }
    }
  }
  return result;
}

// === Confidence score (same logic as functions/lib/confidence.ts) ===

function computeConfidenceScore(aiConfidence, extractedFields) {
  let score = aiConfidence === 'high' ? 0.9 : aiConfidence === 'medium' ? 0.6 : 0.3;

  const totalFields = Object.values(extractedFields).filter(v => v != null).length;
  score += Math.min(totalFields * 0.01, 0.08);

  for (const [key, value] of Object.entries(extractedFields)) {
    if (value && key.includes('date')) {
      if (!/\d{4}[-/]\d{1,2}[-/]\d{1,2}/.test(value) && !/\d{1,2}[-/]\d{1,2}[-/]\d{2,4}/.test(value)) {
        score -= 0.1;
      }
    }
  }

  const lotValue = extractedFields['lot_number'] || extractedFields['batch_number'];
  if (lotValue && lotValue.length < 3) {
    score -= 0.05;
  }

  return Math.max(0, Math.min(1, score));
}

// === Main loop ===

console.log(`Dox process worker started`);
console.log(`  API: ${DOX_API_URL}`);
console.log(`  Qwen: ${QWEN_URL}`);
console.log(`  Poll interval: ${POLL_INTERVAL / 1000}s`);
console.log('');

// Immediate first poll, then interval
poll();
setInterval(poll, POLL_INTERVAL);
