#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

PID_FILE=".qwen-proxy.pid"
LOG_FILE="logs/qwen-proxy.log"

# Refuse if systemd is managing it — use `sudo systemctl restart qwen-proxy.service` instead.
if systemctl is-active --quiet qwen-proxy.service 2>/dev/null; then
  echo "Error: qwen-proxy.service is active under systemd."
  echo "Manage it with: sudo systemctl {start,stop,restart} qwen-proxy.service"
  exit 1
fi

# Refuse if already running via this script
if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "Error: qwen-proxy already running (PID $(cat "$PID_FILE"))"
  exit 1
fi

# Refuse if any node qwen-proxy is running outside our PID file
EXISTING=$(pgrep -f "node.*bin/qwen-proxy" || true)
if [ -n "$EXISTING" ]; then
  echo "Error: a qwen-proxy node process is already running (PID $EXISTING)"
  exit 1
fi

mkdir -p logs

nohup node bin/qwen-proxy > "$LOG_FILE" 2>&1 &
PROXY_PID=$!
echo "$PROXY_PID" > "$PID_FILE"

echo "Qwen proxy started (PID: $PROXY_PID)"
echo "Logs: $LOG_FILE"
echo "Stop: bin/qwen-proxy-stop"
