#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

# ----- Pre-flight: e2e test gate -----
# Runs the full vitest + Playwright suite against staging before we ever
# touch prod. Set SKIP_E2E=1 to bypass (emergencies only).
if [[ "${SKIP_E2E:-0}" != "1" ]]; then
  echo "==> Pre-flight: running e2e against staging"
  ./bin/e2e
else
  echo "==> SKIPPING e2e (SKIP_E2E=1)"
fi

echo
echo "=== Deploying dox to Cloudflare ==="

# Build
echo "Building frontend..."
npm run build

# Deploy to Cloudflare Pages
echo "Deploying to Cloudflare Pages..."
npx wrangler pages deploy dist --project-name doc-upload-site

echo ""
echo "=== Deployment complete ==="
echo "URL: https://supdox.com"
