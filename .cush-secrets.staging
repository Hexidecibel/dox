schema = 1

[defaults]
target_vault = "cush"
target_item = "{project}-staging"
field_template = "{key}"

[secrets]
JWT_SECRET = { ref = "op://cush/doc-upload-site-staging/jwt_secret", target_vault = "cush", target_item = "doc-upload-site-staging" }
RESEND_API_KEY = { ref = "op://cush/doc-upload-site-staging/resend_api_key", target_vault = "cush", target_item = "doc-upload-site-staging" }
QWEN_URL = { ref = "op://cush/doc-upload-site-staging/qwen_url", target_vault = "cush", target_item = "doc-upload-site-staging" }
QWEN_SECRET = { ref = "op://cush/doc-upload-site-staging/qwen_secret", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_D1_ID = { ref = "op://cush/doc-upload-site-staging/staging_d1_id", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_D1_NAME = { ref = "op://cush/doc-upload-site-staging/staging_d1_name", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_R2_BUCKET = { ref = "op://cush/doc-upload-site-staging/staging_r2_bucket", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_PAGES_PROJECT = { ref = "op://cush/doc-upload-site-staging/staging_pages_project", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_URL = { ref = "op://cush/doc-upload-site-staging/staging_url", target_vault = "cush", target_item = "doc-upload-site-staging" }
STAGING_API_KEY = { ref = "op://cush/doc-upload-site-staging/staging_api_key", target_vault = "cush", target_item = "doc-upload-site-staging" }
QWEN_VLM_MODE = { ref = "op://cush/doc-upload-site-staging/qwen_vlm_mode", target_vault = "cush", target_item = "doc-upload-site-staging" }
QWEN_VLM_MAX_PAGES = { ref = "op://cush/doc-upload-site-staging/qwen_vlm_max_pages", target_vault = "cush", target_item = "doc-upload-site-staging" }
CONNECTOR_POLL_TOKEN = { ref = "op://cush/doc-upload-site-staging/connector_poll_token", target_vault = "cush", target_item = "doc-upload-site-staging" }
INTAKE_ENCRYPTION_KEY = { ref = "op://cush/doc-upload-site-staging/intake_encryption_key", target_vault = "cush", target_item = "doc-upload-site-staging" }
CLOUDFLARE_API_TOKEN = { ref = "op://cush/doc-upload-site/cloudflare_api_token", target_vault = "cush", target_item = "doc-upload-site" }
CLOUDFLARE_ACCOUNT_ID = { ref = "op://cush/doc-upload-site/cloudflare_account_id", target_vault = "cush", target_item = "doc-upload-site" }
